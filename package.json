{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "export-data": "node ./src/data/export.js",
    "migrate-schema": "node ./src/data/migrate-to-new-schema.js",
    "migrate-schema:dry-run": "node ./src/data/migrate-to-new-schema.js --dry-run",
    "seed": "node ./src/data/seed.js ./src/data/data.json",
    "seed:dry-run": "node ./src/data/seed.js ./src/data/data.json --dry-run",
    "seed:custom": "node ./src/data/seed.js",
    "migrate-audio": "node ./src/data/migrate-audio-index.js",
    "migrate-to-blob": "node ./src/data/migrate-to-vercel-blob.js",
    "sync-vercel-index": "node ./src/data/sync-vercel-index.js",
    "migrate-challenges-published": "tsx scripts/migrate-challenges-to-published.ts",
    "dev": "npm run export-data -- --overwrite=false --dev && next dev --turbopack",
    "validate-audio": "node ./src/scripts/validateAudioReferences.js",
    "build": "npm run export-data -- --overwrite=true && node ./src/data/export-audio.js && npm run validate-audio && next build",
    "export-audio": "node ./src/data/export-audio-index.js",
    "migrate-to-mongodb": "node ./src/data/migrate-to-mongodb.js",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.6",
    "@ffmpeg/util": "^0.12.1",
    "@fix-webm-duration/fix": "^1.0.1",
    "@realfavicongenerator/check-favicon": "^0.4.18",
    "@types/uuid": "^10.0.0",
    "@vercel/analytics": "^1.4.1",
    "@vercel/blob": "^2.0.0",
    "@vercel/functions": "^3.1.4",
    "classnames": "^2.5.1",
    "dotenv": "^17.2.3",
    "firebase": "^12.4.0",
    "fuse.js": "^7.0.0",
    "jsondiffpatch": "^0.7.3",
    "mongodb": "^6.12.0",
    "next": "^16.0.1",
    "node-html-parser": "^7.0.1",
    "openai": "^4.104.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0",
    "react-window": "^2.2.2",
    "react-window-infinite-loader": "^2.0.0",
    "recharts": "^3.5.0",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^20.17.14",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/react-window": "^1.8.8",
    "eslint": "^9",
    "eslint-config-next": "15.1.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
